---
/**
 * Editor Page — Feature 2: Collaborative district drawing tool.
 * Hosts the DistrictEditor Svelte island where users can paint census tracts
 * into 8 congressional districts, view real-time metrics, and save/share maps.
 * Actual editor component will be built in Phase 3.
 */

import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Draw Your Map"
  description="Create your own Missouri congressional district plan. Paint census tracts, check population balance, and share your map."
>
  <!-- Page header -->
  <section class="bg-mo-navy text-white py-10">
    <div class="container-site">
      <h1 class="font-headline text-3xl font-bold mb-2">Draw Your Map</h1>
      <p class="text-white/70 max-w-2xl">
        Think you can draw fairer districts? Select a district color, paint census tracts,
        and watch population and fairness metrics update in real time. Save and share your plan.
      </p>
    </div>
  </section>

  <!-- Editor container — Svelte island will mount here in Phase 3 -->
  <section class="container-site py-8">
    <div class="rounded-lg border border-mo-neutral-200 bg-white shadow-sm overflow-hidden">
      {/* Placeholder for DistrictEditor.svelte (client:load) */}
      <div class="h-[600px] md:h-[750px] flex items-center justify-center bg-mo-neutral-100">
        <div class="text-center text-mo-neutral-600">
          <p class="text-lg font-semibold mb-2">District Editor</p>
          <p class="text-sm">Interactive painting tool — coming in Phase 3</p>
        </div>
      </div>
    </div>

    <!-- How it works -->
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-5 rounded-lg bg-mo-neutral-100">
        <h3 class="font-headline font-bold text-mo-neutral-800 mb-2">1. Pick a District</h3>
        <p class="text-sm text-mo-neutral-600">
          Choose from 8 color-coded district slots in the sidebar.
        </p>
      </div>
      <div class="p-5 rounded-lg bg-mo-neutral-100">
        <h3 class="font-headline font-bold text-mo-neutral-800 mb-2">2. Paint Tracts</h3>
        <p class="text-sm text-mo-neutral-600">
          Click or drag over census tracts to assign them. Population counters update live.
        </p>
      </div>
      <div class="p-5 rounded-lg bg-mo-neutral-100">
        <h3 class="font-headline font-bold text-mo-neutral-800 mb-2">3. Save & Share</h3>
        <p class="text-sm text-mo-neutral-600">
          Get a permalink to your map. Publish it to the community gallery for others to see.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
