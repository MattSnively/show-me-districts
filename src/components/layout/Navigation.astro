---
/**
 * Navigation — Site header with logo, tagline, and main nav bar.
 * Navy background nav bar with gold accent on hover/active links.
 * Responsive: collapses to hamburger menu on mobile (<768px).
 * Includes aria-current for screen reader page identification.
 *
 * Props:
 *   currentPath — The current page path, used to highlight the active nav link.
 */

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

/** Navigation links matching the site structure */
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/history', label: 'History' },
  { href: '/editor', label: 'Draw Your Map' },
  { href: '/fair-maps', label: 'Fair Maps' },
  { href: '/redistricting-2025', label: '2025 Remap' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-white border-b border-mo-neutral-200">
  <!-- Top section: logo and tagline -->
  <div class="container-site py-5 pb-3 flex items-baseline justify-between flex-wrap gap-3
              max-md:text-center max-md:justify-center">
    <div>
      <a href="/" class="no-underline hover:no-underline" aria-label="Show-Me Districts home page">
        <div class="font-headline text-[2rem] font-bold text-mo-navy tracking-tight">
          SHOW-ME <span class="text-mo-gold">DISTRICTS</span>
        </div>
      </a>
      <div class="text-sm text-mo-neutral-600 italic">
        Missouri's congressional districts — past, present, and reimagined
      </div>
    </div>
  </div>

  <!-- Navigation bar -->
  <nav class="bg-mo-navy" aria-label="Main navigation">
    <div class="container-site flex items-center justify-between md:justify-start">
      <!-- Mobile hamburger button -->
      <button
        id="nav-toggle"
        class="md:hidden text-white p-3 focus:outline-none focus:ring-2 focus:ring-mo-gold rounded"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Toggle navigation menu"
      >
        <!-- Hamburger icon (3 lines) -->
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Nav links — hidden on mobile until toggled -->
      <div
        id="nav-menu"
        class="hidden md:flex md:flex-wrap w-full md:w-auto"
      >
        {navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              class:list={[
                'block text-white px-5 py-3 text-sm font-semibold uppercase tracking-wide transition-colors',
                'hover:bg-mo-gold hover:text-mo-navy hover:no-underline',
                'focus:outline-none focus:ring-2 focus:ring-inset focus:ring-mo-gold',
                { 'bg-mo-gold text-mo-navy': isActive },
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          );
        })}
      </div>
    </div>
  </nav>
</header>

<!-- Mobile menu toggle script — vanilla JS for zero framework overhead -->
<script>
  /** Wire up the hamburger menu toggle on mobile screens */
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  if (toggle && menu && hamburgerIcon && closeIcon) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('hidden');

      /* Toggle menu visibility */
      menu.classList.toggle('hidden');

      /* Swap hamburger ↔ close icon */
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');

      /* Update aria-expanded for screen readers */
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
